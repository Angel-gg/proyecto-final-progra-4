  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.3.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.1.0",
    "prisma": "^5.10.0",
    "vitest": "^1.3.0"
  }
}
