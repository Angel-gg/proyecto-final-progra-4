# =====================================================
# Variables de Entorno — El Surtidor Cochabambino
# =====================================================
# Copia este archivo como .env y completa los valores.
# En Vercel: añade estas variables en Project Settings > Environment Variables

# Base de Datos SQLite (local)
# Para producción en Vercel, dejar como está (SQLite en /tmp o en el repo)
DATABASE_URL="file:./dev.db"

# Para migrar a Supabase PostgreSQL (opcional, producción robusta):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
